generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  clientId     String   @id @map("client_id")
  username     String?  @unique
  passwordHash String?  @map("password_hash")
  passwordSalt String?  @map("password_salt")
  inviteCode   String   @unique @map("invite_code")
  referredBy   String?  @map("referred_by")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  payments      Payment[]
  entitlement   Entitlement?
  tasks         Task[]
  creditEntries CreditLedger[]
  sessions      AuthSession[]

  @@map("accounts")
}

model AuthSession {
  id        String   @id
  clientId  String   @map("client_id")
  tokenHash String   @unique @map("token_hash")
  userAgent String?  @map("user_agent")
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  account Account @relation(fields: [clientId], references: [clientId], onDelete: Cascade)

  @@index([clientId, expiresAt])
  @@map("auth_sessions")
}

model Entitlement {
  clientId  String    @id @map("client_id")
  planId    String    @map("plan_id")
  paymentId String    @unique @map("payment_id")
  startsAt  DateTime  @default(now()) @map("starts_at")
  expiresAt DateTime? @map("expires_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  account Account @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@map("entitlements")
}

model Payment {
  id          String    @id
  clientId    String    @map("client_id")
  planId      String    @map("plan_id")
  amountCents Int       @map("amount_cents")
  status      String
  createdAt   DateTime  @default(now()) @map("created_at")
  paidAt      DateTime? @map("paid_at")

  account      Account       @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  entitlement  Entitlement?

  @@index([clientId, createdAt])
  @@map("payments")
}

model Task {
  id        String   @id
  clientId  String?  @map("client_id")
  workflow  String
  status    String
  prompt    String?
  payload   Json     @map("payload_json")
  response  Json     @map("response_json")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  account Account? @relation(fields: [clientId], references: [clientId], onDelete: SetNull)
  assets  Asset[]

  @@index([clientId, createdAt])
  @@map("tasks")
}

model Asset {
  id           String   @id
  taskId       String   @map("task_id")
  role         String
  originalName String?  @map("original_name")
  mimeType     String?  @map("mime_type")
  filePath     String   @map("file_path")
  publicUrl    String   @map("public_url")
  sizeBytes    Int      @map("size_bytes")
  createdAt    DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@map("assets")
}

model CreditLedger {
  id          String   @id
  clientId    String   @map("client_id")
  amountUnits Int      @map("amount_units")
  reason      String
  referenceId String?  @map("reference_id")
  createdAt   DateTime @default(now()) @map("created_at")

  account Account @relation(fields: [clientId], references: [clientId], onDelete: Cascade)

  @@index([clientId, createdAt])
  @@map("credit_ledger")
}
